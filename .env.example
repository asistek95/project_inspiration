# ============================================================
# Beleg Pilot — Umgebungsvariablen
# Kopiere diese Datei zu .env.local und fülle die Werte aus.
# NIEMALS echte Werte in .env.example eintragen!
# ============================================================

# === Supabase (Datenbank + Auth) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI Provider (Claude / Anthropic) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# Wenn ANTHROPIC_API_KEY leer => Demo-Modus mit Beispieltexten

# === Admin-Panel (komma-getrennte E-Mail-Whitelist) ===
ADMIN_EMAILS=amin@klarblick.com,amin.sistek20@gmail.com

# ============================================================
# WhatsApp via Twilio
# Setup: https://console.twilio.com → Messaging → WhatsApp
# Webhook URL: https://app.klarblick.at/api/whatsapp
# ============================================================
TWILIO_ACCOUNT_SID=                        # AC...
TWILIO_AUTH_TOKEN=                         # HMAC-Signaturvalidierung — PFLICHT für Produktion
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886 # Sandbox: +14155238886 | Produktion: eigene Twilio-Nummer

# ============================================================
# E-Mail Inbound Webhook
# Wähle EINEN Provider. Webhook URL: https://app.klarblick.at/api/email/webhook
#
# Option A) Postmark Inbound (empfohlen für MVP):
#   - Inbound Domain anlegen: mail.klarblick.at (MX-Record auf inbound.postmarkapp.com)
#   - Webhook-URL in Postmark Inbound Console eintragen
#   - Inbound Hash aus Postmark als POSTMARK_INBOUND_TOKEN
#
# Option B) Mailgun Inbound:
#   - Route anlegen: match_recipient("belege@klarblick.at") → forward webhook
#   - Signing Key aus Mailgun Dashboard
#
# Option C) SendGrid Inbound Parse:
#   - MX-Record auf mx.sendgrid.net, Parse Webhook URL eintragen
#
# Option D) Gmail → eigene Adresse weiterleiten (einfachster MVP):
#   - User richtet Gmail-Weiterleitung auf belege+<userId>@klarblick.at ein
#   - Kein separater Provider nötig, funktioniert mit Option A/B/C
# ============================================================
POSTMARK_INBOUND_TOKEN=                    # Aus Postmark → Server → Inbound
MAILGUN_SIGNING_KEY=                       # Aus Mailgun → Settings → API Keys → HTTP webhook signing key
SENDGRID_WEBHOOK_SECRET=                   # Aus SendGrid → Settings → Inbound Parse
INBOUND_EMAIL_DOMAIN=mail.klarblick.at     # Domain die MX auf Mail-Provider zeigt

# ============================================================
# Gmail Push Notifications (optional — Alternative zu Inbound Mail)
# Benötigt: Google Cloud Project, Pub/Sub Topic, Service Account
# Webhook URL: https://app.klarblick.at/api/email/gmail-push
# Anleitung: https://developers.google.com/gmail/api/guides/push
#
# EMPFEHLUNG: Für MVP lieber Postmark Inbound verwenden (einfacher).
# Gmail Push nur wenn User explizit Gmail-Konto koppeln sollen.
# ============================================================
GOOGLE_CLIENT_ID=                          # Google Cloud Console → OAuth 2.0 Client
GOOGLE_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC=                       # projects/<project>/topics/<topic>
GOOGLE_SERVICE_ACCOUNT_EMAIL=             # Service Account für Pub/Sub
GOOGLE_SERVICE_ACCOUNT_KEY=               # Base64-kodierter JSON-Schlüssel

# ============================================================
# App-Konfiguration
# ============================================================
NEXT_PUBLIC_APP_URL=https://app.klarblick.at
NEXT_PUBLIC_SUPPORT_EMAIL=support@klarblick.at
NEXT_PUBLIC_WHATSAPP_NUMBER=+43XXXXXXXXXX  # Twilio Produktions-WhatsApp-Nummer (angezeigt in UI)

# ============================================================
# Stripe (vorerst ausgelassen — für spätere Payment-Integration)
# ============================================================
# NEXT_PUBLIC_STRIPE_LINK_STARTER=
# NEXT_PUBLIC_STRIPE_LINK_PROFI=
# NEXT_PUBLIC_STRIPE_LINK_BETRIEB=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
